# Stripe Checkout for the 60-minute design consultation.
# Required for live payments and payment verification.
STRIPE_SECRET_KEY=replace_with_stripe_secret_key

# Optional. If omitted, the app creates a one-time $595 USD Checkout line item.
STRIPE_DESIGN_CONSULTATION_PRICE_ID=

# Used for Stripe success/cancel URLs in production.
NEXT_PUBLIC_SITE_URL=https://petersandel.com
